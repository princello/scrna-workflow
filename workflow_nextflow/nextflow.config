// scRNA cohort workflow — Nextflow config.
// Same logical config as ../config.yaml, expressed in the groovy idiom (kept in sync by hand). The
// analysis code in ../scripts is shared with the Snakemake port; only the orchestration differs.

params {
    outdir  = "results_nextflow"
    scripts = "${projectDir}/../scripts"

    // each sample = [name, subsample_fraction, seed]
    samples = [
        ['s1', 0.8, 1],
        ['s2', 0.6, 2],
        ['s3', 0.7, 3],
    ]

    min_genes   = 200
    min_cells   = 3
    max_pct_mt  = 10
    n_hvg       = 2000
    n_pcs       = 30
    resolution  = 1.0
    top_markers = 10
}

process.executor = 'local'
dag.overwrite    = true
